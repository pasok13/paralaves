  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'inventory_backup_' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
  showToast('Backup αποθηκεύτηκε');
}
function importBackup() { document.getElementById('backup-input').click(); }
function loadBackupFile(file) {
  if (!file) return;
  const r = new FileReader();
  r.onload = ev => {
    try {
      const p = JSON.parse(ev.target.result);
      if (p.data) { data = p.data; }
      if (p.catalog_extra) Object.assign(C, p.catalog_extra);
      render(); saveAll();
      showToast('Backup φορτώθηκε επιτυχώς!');
    } catch (e) { showToast('Σφάλμα φόρτωσης backup', true); }
  };
  r.readAsText(file);
}

