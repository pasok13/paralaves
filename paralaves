  .gbadge { font-size: 8pt; font-weight: bold; padding: 2px 7px; border-radius: 20px; margin-left: auto; }
  .gbadge.blue { background: #dce8fe; color: #1a56db; margin-left: auto; }
  .gbadge.green { background: #d4edda; color: #1e7e34; margin-left: 4px; }

  .chips { padding: 8px 10px; display: flex; flex-wrap: wrap; gap: 6px; align-items: flex-end; }
  .chip { display: inline-flex; flex-direction: column; align-items: center; justify-content: flex-end; background: #f5f5f0; border: 0.5px solid #ddd; border-radius: 4px; padding: 4px 10px 5px; min-width: 48pt; }
