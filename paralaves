// ---- SAVE RECEIPT ----
const SAVED_RECEIPTS_KEY = 'inv_saved_receipts';
function getSavedReceipts() {
  return idbKvGet(SAVED_RECEIPTS_KEY).then(v => v || []).catch(() => []);
}
function setSavedReceipts(arr) { return idbKvSet(SAVED_RECEIPTS_KEY, arr); }

function openSaveReceipt() {
  if (!Object.keys(data).length) { showToast('Δεν υπάρχουν δεδομένα για αποθήκευση', true); return; }
  const titleInput = document.getElementById('sr-title');
  const dateInput = document.getElementById('sr-date');
  titleInput.value = document.getElementById('receipt-title').value || '';
  dateInput.value = new Date().toISOString().slice(0, 10);
  const skuCount = Object.keys(data).length;
  const totalPcs = Object.values(data).reduce((s,v)=>s+Object.values(v.sizes).reduce((a,b)=>a+b,0),0);
  document.getElementById('sr-hint').textContent = skuCount + ' SKU · ' + totalPcs + ' τεμάχια';
  document.getElementById('save-receipt-modal').className = 'modal-bg open';
  setTimeout(() => titleInput.focus(), 100);
}

function doSaveReceipt() {
  const title = document.getElementById('sr-title').value.trim();
  const date = document.getElementById('sr-date').value;
  if (!title) { document.getElementById('sr-title').focus(); showToast('Εισάγετε τίτλο', true); return; }
  getSavedReceipts().then(receipts => {
    const id = 'r_' + Date.now();
    receipts.unshift({ id, title, date, data: JSON.parse(JSON.stringify(data)), savedAt: new Date().toISOString() });
    return setSavedReceipts(receipts);
  }).then(() => {
    document.getElementById('receipt-title').value = title;
    closeModal('save-receipt-modal');
    showToast('Παραλαβή "' + title + '" αποθηκεύτηκε!');
    updateSavedBadge();
  });
}

function updateSavedBadge() {
  getSavedReceipts().then(receipts => {
    const count = receipts.length;
    document.querySelectorAll('.tab-btn')[1].textContent = '📂 Αποθηκευμένες Παραλαβές' + (count ? ' (' + count + ')' : '');
  });
}

function renderSavedList() {
  getSavedReceipts().then(receipts => {
  const list = document.getElementById('saved-list');
  const empty = document.getElementById('saved-empty');
  list.innerHTML = '';
  if (!receipts.length) { empty.style.display = 'block'; updateSavedBadge(); return; }
  empty.style.display = 'none';
  updateSavedBadge();
  receipts.forEach(r => {
    const skuCount = Object.keys(r.data).length;
    const totalPcs = Object.values(r.data).reduce((s,v)=>s+Object.values(v.sizes).reduce((a,b)=>a+b,0),0);
    const dateDisp = r.date ? new Date(r.date + 'T00:00:00').toLocaleDateString('el-GR') : '';
    const savedStr = new Date(r.savedAt).toLocaleString('el-GR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});
    const item = document.createElement('div');
    item.className = 'saved-item';
    item.innerHTML = `
      <div class="saved-item-info">
        <div class="saved-item-title">${r.title}</div>
        <div class="saved-item-meta">${dateDisp ? dateDisp + ' · ' : ''}${skuCount} SKU · ${totalPcs} τεμ. · Αποθ. ${savedStr}</div>
      </div>
      <div class="saved-item-actions">
        <button class="btn" style="font-size:12px" onclick="loadReceipt('${r.id}')">✏️ Άνοιγμα</button>
        <button class="btn" style="font-size:12px;background:#fff3e0;border-color:#ffb74d;color:#e65100" onclick="exportPDFFromSaved('${r.id}')">📄 PDF</button>
        <button class="btn" style="font-size:12px;color:#c0392b" onclick="deleteReceipt('${r.id}')">✕</button>
      </div>`;
    list.appendChild(item);
  });
  });
}

function loadReceipt(id) {
  getSavedReceipts().then(receipts => {
    const r = receipts.find(x => x.id === id);
    if (!r) return;
    if (Object.keys(data).length && !confirm('Η τρέχουσα παραλαβή θα αντικατασταθεί. Συνέχεια;')) return;
    data = JSON.parse(JSON.stringify(r.data));
    // Re-attach photos from IndexedDB (they aren't stored in receipt to save space)
    Object.keys(data).forEach(sku => {
      if (_allStoredPhotos[sku]) data[sku].photo = _allStoredPhotos[sku];
    });
    document.getElementById('receipt-title').value = r.title;
    saveAll();
    render();
    switchTab('scan');
