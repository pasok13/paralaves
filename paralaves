  const win = window.open('', '_blank');
  if (!win) { showToast('Επιτρέψτε τα pop-ups για PDF', true); return; }
  win.document.write(html);
  win.document.close();
  showToast('Άνοιξε παράθυρο εκτύπωσης — επιλέξτε "Αποθήκευση ως PDF"');
}

