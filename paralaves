  @media print {
    body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  }
</style>
</head>
<body>
  <div class="header">
    <div class="header-left">
      <h1>ΔΕΛΤΙΟ ΠΑΡΑΛΑΒΗΣ</h1>
      ${titleLine}
    </div>
    <span class="dt">${displayDate}</span>
  </div>
  <div class="summary">
    <div class="sbox"><div class="slabel">Catalog barcodes</div><div class="sval">${Object.keys(C).length}</div></div>
