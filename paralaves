// ---- BULK PHOTO IMPORT ----
function openBulkPhotoImport() {
  document.getElementById('bulk-photo-results').style.display = 'none';
  document.getElementById('bulk-photo-modal').className = 'modal-bg open';
}

function handleBulkPhotoDrop(e) {
  e.preventDefault();
  document.getElementById('bulk-drop-zone').classList.remove('drag');
  handleBulkPhotoUpload(e.dataTransfer.files);
}

function handleBulkPhotoUpload(files) {
  if (!files || !files.length) return;
  const fileArr = Array.from(files);
  let matched = [], unmatched = [], done = 0;

  // Normalize: uppercase, strip all non-alphanumeric
  function norm(s) { return s.toUpperCase().replace(/[^A-Z0-9]/g, ''); }

  // Levenshtein distance
  function lev(a, b) {
    const m = a.length, n = b.length;
    const dp = Array.from({length: m+1}, (_, i) => Array.from({length: n+1}, (_, j) => i === 0 ? j : j === 0 ? i : 0));
    for (let i = 1; i <= m; i++)
      for (let j = 1; j <= n; j++)
        dp[i][j] = a[i-1] === b[j-1] ? dp[i-1][j-1] : 1 + Math.min(dp[i-1][j], dp[i][j-1], dp[i-1][j-1]);
    return dp[m][n];
  }

  // Find best SKU match: search both scanned data AND full catalog
  const skuKeys = [...new Set([...Object.keys(data), ...Object.values(C).map(v => v.sku)])];
  const skuNorms = skuKeys.map(norm);

  function findBestSku(filename) {
    const nameNorm = norm(filename.replace(/\.[^.]+$/, ''));
    // 1. Exact match
    const exactIdx = skuNorms.indexOf(nameNorm);
    if (exactIdx !== -1) return { sku: skuKeys[exactIdx], exact: true };
    // 2. Contains match (SKU is substring of filename or vice versa)
    for (let i = 0; i < skuNorms.length; i++) {
      if (nameNorm.includes(skuNorms[i]) || skuNorms[i].includes(nameNorm)) {
        return { sku: skuKeys[i], exact: false, hint: 'περιέχει' };
      }
    }
    // 3. Fuzzy: find closest SKU with distance ≤ 3 and similarity ≥ 80%
    let bestSku = null, bestDist = Infinity;
    for (let i = 0; i < skuNorms.length; i++) {
      const maxLen = Math.max(nameNorm.length, skuNorms[i].length);
      const d = lev(nameNorm, skuNorms[i]);
      const similarity = (maxLen - d) / maxLen;
      if (d < bestDist && d <= 3 && similarity >= 0.80) {
        bestDist = d; bestSku = { sku: skuKeys[i], exact: false, hint: d + ' διαφορές' };
      }
    }
    return bestSku;
  }

  function compressImage(file, cb) {
    const reader = new FileReader();
    reader.onload = function(e) {
      const img = new Image();
      img.onload = function() {
        const MAX = 600;
        const scale = Math.min(1, MAX / img.width, MAX / img.height);
        const w = Math.round(img.width * scale), h = Math.round(img.height * scale);
        const canvas = document.createElement('canvas');
        canvas.width = w; canvas.height = h;
        canvas.getContext('2d').drawImage(img, 0, 0, w, h);
        cb(canvas.toDataURL('image/jpeg', 0.75));
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  }

  function processOne(file, cb) {
    const match = findBestSku(file.name);
    if (!match) {
      // No SKU match yet — save as pending with normalized filename key
      compressImage(file, dataUrl => {
        const nameNorm = normStr(file.name.replace(/\.[^.]+$/, ''));
        idbSetPendingPhoto(nameNorm, file.name, dataUrl)
          .then(() => { unmatched.push(file.name); cb(); })
          .catch(() => { unmatched.push(file.name); cb(); });
      });
      return;
    }
    const realSku = match.sku;
    compressImage(file, dataUrl => {
      if (data[realSku]) data[realSku].photo = dataUrl;
      _allStoredPhotos[realSku] = dataUrl;
      idbSetPhoto(realSku, dataUrl).catch(() => {});
      matched.push({ file: file.name, sku: realSku, exact: match.exact, hint: match.hint });
      cb();
    });
  }

  function next(i) {
    if (i >= fileArr.length) {
      saveAll(); render();
      // Show results
      const res = document.getElementById('bulk-photo-results');
      let html = '';
      if (matched.length) {
        html += `<div style="background:#e6f4ea;border:0.5px solid #a8d5b5;border-radius:8px;padding:10px 12px;margin-bottom:8px">
          <div style="font-size:12px;font-weight:600;color:#1e7e34;margin-bottom:6px">✓ Αντιστοιχίστηκαν ${matched.length} φωτογραφίες</div>
          <div style="font-size:11px;color:#555;display:flex;flex-direction:column;gap:2px">
            ${matched.map(m => `<span><strong>${m.sku}</strong> ← ${m.file}${!m.exact && m.hint ? ` <span style="color:#b45309;font-size:10px">(~${m.hint})</span>` : ''}</span>`).join('')}
          </div>
        </div>`;
      }
      if (unmatched.length) {
        html += `<div style="background:#fff7ed;border:0.5px solid #fdba74;border-radius:8px;padding:10px 12px">
          <div style="font-size:12px;font-weight:600;color:#c2410c;margin-bottom:4px">⏳ ${unmatched.length} φωτογραφίες αποθηκεύτηκαν ως εκκρεμείς</div>
          <div style="font-size:11px;color:#78350f;margin-bottom:6px">Θα συνδεθούν αυτόματα όταν σκαναριστεί το αντίστοιχο barcode</div>
          <div style="font-size:11px;color:#555;display:flex;flex-direction:column;gap:2px">
            ${unmatched.map(f => `<span>📄 ${f}</span>`).join('')}
          </div>
        </div>`;
      }
      res.innerHTML = html;
      res.style.display = 'block';
      showToast(matched.length + ' αντιστοιχίστηκαν' + (unmatched.length ? ', ' + unmatched.length + ' εκκρεμείς' : ''));
      return;
    }
    processOne(fileArr[i], () => next(i + 1));
  }
  next(0);
}

