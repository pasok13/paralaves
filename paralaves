function openManageCatalog() {
  const extra = getCatalogExtra();
  const el = document.getElementById('manage-catalog-body');

  // Group barcodes by SKU
  const bySkU = {};
  Object.entries(extra).forEach(([bc, entry]) => {
    if (!bySkU[entry.sku]) bySkU[entry.sku] = { name: entry.name || '', barcodes: [] };
    bySkU[entry.sku].barcodes.push({ bc, size: entry.size });
  });

  const skus = Object.keys(bySkU).sort();
  if (!skus.length) {
    el.innerHTML = '<div style="text-align:center;padding:1.5rem;color:#888">Δεν υπάρχουν barcodes από Excel.<br>Εισάγετε παραγγελία για να εμφανιστούν εδώ.</div>';
  } else {
    el.innerHTML = skus.map(sku => {
      const g = bySkU[sku];
      const bcList = g.barcodes.sort((a,b) => a.size.localeCompare(b.size))
        .map(b => `<span style="font-size:10px;font-family:monospace;background:#f5f5f0;border:0.5px solid #ddd;border-radius:4px;padding:1px 6px;white-space:nowrap">Νο${b.size}: ${b.bc}</span>`).join(' ');
