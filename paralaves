function exportPDFData(pdfData, receiptTitle, receiptDate, photosOn) {
  const skus = Object.keys(pdfData).sort();
  if (!skus.length) { showToast('Δεν υπάρχουν δεδομένα', true); return; }

  const now = new Date();
  const dateStr = now.toLocaleDateString('el-GR') + ' ' + now.toLocaleTimeString('el-GR', {hour:'2-digit', minute:'2-digit'});
  const displayDate = receiptDate || dateStr;

  let totalSizes = 0, totalPcs = 0;
  skus.forEach(sku => {
    Object.keys(pdfData[sku].sizes).forEach(sz => { totalSizes++; totalPcs += pdfData[sku].sizes[sz]; });
  });

  // Build SKU group HTML — horizontal chips: Νο(qty)
  let groupsHTML = '';
  skus.forEach(sku => {
    const sizes = Object.keys(pdfData[sku].sizes).sort((a,b) => {
      const n = s => parseFloat(s.replace(/[^0-9.]/g,'')) || 0; return n(a)-n(b);
    });
    const gt = sizes.reduce((s,sz) => s + pdfData[sku].sizes[sz], 0);
    const pn = pdfData[sku].name ? `<span class="pname">${pdfData[sku].name}</span>` : '';
    const noteStr = pdfData[sku].notes ? `<span class="pnote">${pdfData[sku].notes}</span>` : '';
    const prices = pdfData[sku].prices || {};
    const allPrices = sizes.map(sz => prices[sz]).filter(p => p != null);
    const uniquePrices = [...new Set(allPrices.map(p => p.toFixed(2)))];
    let priceStr = '';
    if (uniquePrices.length === 1) {
      priceStr = `<span class="pprice">€${uniquePrices[0]}</span>`;
    } else if (uniquePrices.length > 1) {
      const minP = Math.min(...allPrices).toFixed(2);
      const maxP = Math.max(...allPrices).toFixed(2);
      priceStr = `<span class="pprice" style="background:#fff3e0;color:#c2410c">€${minP}–${maxP}</span>`;
    } else if (pdfData[sku].price != null) {
      priceStr = `<span class="pprice">€${Number(pdfData[sku].price).toFixed(2)}</span>`;
    }
    const chips = sizes.map((sz, idx) => {
      const q = pdfData[sku].sizes[sz];
      const szPrice = prices[sz];
      const prevPrice = idx > 0 ? prices[sizes[idx - 1]] : undefined;
      // Show price label only at the first occurrence or when price changes
      const showPrice = szPrice != null && (idx === 0 ? true : szPrice !== prevPrice);
      const pricePart = showPrice ? `<span class="chipp">€${szPrice.toFixed(2)}</span>` : (szPrice != null ? '<span class="chipp-spacer"></span>' : '');
      return `<span class="chip${q > 1 ? ' multi' : ''}">${pricePart}<span class="chiprow"><span class="chipnum">${sz}</span><span class="chipq">(${q})</span></span></span>`;
    }).join('');
    const photoStr = (photosOn && pdfData[sku].photo) ? `<div class="gbody">
        <div class="gphoto"><img src="${pdfData[sku].photo}" alt="${sku}"></div>
        <div class="chips">${chips}</div>
      </div>` : `<div class="chips">${chips}</div>`;
    groupsHTML += `
      <div class="group">
        <div class="ghead">
          <span class="gsku">${sku}</span>${pn}${noteStr}${priceStr}
          <span class="gbadge blue">${sizes.length} νούμερα</span>
          <span class="gbadge green">${gt} τεμ.</span>
        </div>
        ${photoStr}
      </div>`;
  });

  const titleLine = receiptTitle ? `<span class="receipt-title-pdf">${receiptTitle}</span>` : '';

  const html = `<!DOCTYPE html>
<html lang="el">
<head>
<meta charset="UTF-8">
<title>Δελτίο Παραλαβής${receiptTitle ? ' — ' + receiptTitle : ''}</title>
<style>
  @page { size: A4; margin: 14mm 14mm 16mm 14mm; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Arial, Helvetica, sans-serif; font-size: 9pt; color: #1a1a1a; background: #fff; }

  .header { background: #1a1a1a; color: #fff; padding: 10px 14px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; border-radius: 4px; }
  .header-left { display: flex; flex-direction: column; gap: 3px; }
  .header h1 { font-size: 14pt; font-weight: bold; letter-spacing: 0.5px; }
  .receipt-title-pdf { font-size: 11pt; color: #ccc; font-weight: 500; }
  .header .dt { font-size: 8pt; color: #ccc; text-align: right; }

  .summary { display: grid; grid-template-columns: repeat(4,1fr); gap: 6px; margin-bottom: 14px; }
  .sbox { background: #f5f5f0; border: 0.5px solid #ddd; border-radius: 4px; padding: 6px 8px; text-align: center; }
  .sbox .slabel { font-size: 8pt; color: #888; margin-bottom: 2px; }
  .sbox .sval { font-size: 17pt; font-weight: bold; color: #1a1a1a; }

  .group { margin-bottom: 8px; page-break-inside: avoid; border: 0.5px solid #ddd; border-radius: 4px; overflow: hidden; }
  .ghead { display: flex; align-items: center; gap: 8px; background: #f0f0eb; padding: 6px 10px; border-bottom: 0.5px solid #ddd; }
  .gsku { font-size: 12pt; font-weight: bold; color: #1a1a1a; }
