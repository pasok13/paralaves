          <div class="catalog-item-sku">${sku}${g.name ? ' <span style="font-size:11px;color:#888;font-weight:400">· ' + g.name + '</span>' : ''}${inData ? ' <span style="font-size:10px;background:#e6f4ea;color:#1e7e34;border-radius:10px;padding:1px 6px">σκαναρισμένο</span>' : ''}</div>
