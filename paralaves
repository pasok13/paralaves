
<!DOCTYPE html>
<html lang="el">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inventory Scanner</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f0;color:#1a1a1a;min-height:100vh;padding:1rem}
.wrap{max-width:860px;margin:0 auto}
h1{font-size:18px;font-weight:500;margin-bottom:1.25rem;color:#1a1a1a}
.summary-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:1.5rem}
.stat{background:#fff;border:0.5px solid #e0e0d8;border-radius:8px;padding:10px 14px}
.stat-label{font-size:11px;color:#888;margin-bottom:2px}
.stat-val{font-size:20px;font-weight:500;color:#1a1a1a}
.scan-area{background:#fff;border:0.5px solid #e0e0d8;border-radius:12px;padding:1rem 1.25rem;margin-bottom:1rem}
.scan-row{display:grid;grid-template-columns:1fr auto;gap:8px;align-items:center}
.scan-input{font-size:15px;padding:8px 12px;border:0.5px solid #ccc;border-radius:8px;width:100%;background:#fff;color:#1a1a1a}
.scan-input:focus{outline:none;border-color:#999;box-shadow:0 0 0 2px rgba(0,0,0,0.07)}
.btn{padding:8px 16px;border:0.5px solid #ccc;border-radius:8px;background:#fff;color:#1a1a1a;cursor:pointer;font-size:14px;white-space:nowrap}
.btn:hover{background:#f5f5f0}
.btn-import{background:#e8f0fe;border-color:#b0c4f5;color:#1a56db;font-weight:500}
.btn-import:hover{opacity:0.85;background:#dce8fd}
.hint{font-size:12px;color:#888;margin-top:6px}
.preview-box{margin-top:10px;padding:10px 12px;border-radius:8px;border:0.5px solid #b0c4f5;background:#e8f0fe;display:none}
.preview-box.err{border-color:#f5b0b0;background:#fee8e8}
.preview-sku{font-size:14px;font-weight:500;color:#1a1a1a}
.preview-name{font-size:12px;color:#555;margin-top:1px}
.preview-detail{font-size:12px;color:#555;margin-top:3px;font-family:monospace}
.group-card{background:#fff;border:0.5px solid #e0e0d8;border-radius:12px;margin-bottom:1rem;overflow:hidden}
.group-header{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:#fafaf7;border-bottom:0.5px solid #e0e0d8;cursor:pointer;user-select:none}
.group-left{display:flex;flex-direction:column;gap:2px}
.group-title{font-size:14px;font-weight:500;color:#1a1a1a}
.group-title:hover{color:#1a56db;text-decoration:underline dotted}
.group-name{font-size:11px;color:#888}
.group-meta{display:flex;align-items:center;gap:8px;flex-shrink:0}
.badge{font-size:11px;padding:2px 8px;border-radius:100px;background:#e8f0fe;color:#1a56db;font-weight:500}
.badge-total{background:#e6f4ea;color:#1e7e34}
.badge-new{background:#e6f4ea;color:#1e7e34;font-size:10px;padding:1px 6px;border-radius:100px;font-weight:500;margin-left:4px}
.chevron{font-size:12px;color:#888;transition:transform 0.2s;display:inline-block}
.chevron.open{transform:rotate(180deg)}
.group-notes{font-size:12px;padding:4px 8px;border:0.5px solid #ddd;border-radius:6px;background:#fafaf7;color:#555;width:220px;outline:none;transition:border-color 0.15s,box-shadow 0.15s;font-family:inherit}
.group-notes:focus{border-color:#999;box-shadow:0 0 0 2px rgba(0,0,0,0.07);background:#fff}
.group-notes::placeholder{color:#bbb}
.group-price-badge{font-size:12px;font-weight:600;color:#1e7e34;background:#e6f4ea;border:0.5px solid #a8d5b5;border-radius:6px;padding:4px 9px;white-space:nowrap;user-select:none}
.size-table{width:100%;border-collapse:collapse}
.size-table th{font-size:11px;color:#888;font-weight:500;padding:6px 14px;text-align:left;border-bottom:0.5px solid #e0e0d8}
.size-table th:last-child,.size-table td:last-child{text-align:right}
.size-table td{font-size:13px;padding:7px 14px;color:#1a1a1a;border-bottom:0.5px solid #e0e0d8}
.size-table tr:last-child td{border-bottom:none}
.size-table tr:hover td{background:#fafaf7}
.qty-cell{display:flex;align-items:center;justify-content:flex-end;gap:6px}
.qty-btn{width:22px;height:22px;border:0.5px solid #ccc;border-radius:4px;background:transparent;cursor:pointer;font-size:14px;line-height:1;color:#555;display:flex;align-items:center;justify-content:center}
.qty-btn:hover{background:#f5f5f0;color:#1a1a1a}
.qty-val{min-width:24px;text-align:center;font-weight:500;font-size:14px}
.empty{text-align:center;padding:2.5rem;color:#888;font-size:14px}
.actions-row{display:flex;gap:8px;margin-bottom:1rem;flex-wrap:wrap;align-items:center}
.save-indicator{font-size:11px;color:#1e7e34;margin-left:auto;padding:4px 10px;background:#e6f4ea;border-radius:100px;display:none}
.save-indicator.show{display:inline-block}
/* Tabs */
.tabs{display:flex;gap:0;margin-bottom:1.5rem;border-bottom:1.5px solid #e0e0d8}
.tab-btn{padding:8px 18px;font-size:13px;font-weight:500;color:#888;background:none;border:none;border-bottom:2.5px solid transparent;cursor:pointer;margin-bottom:-1.5px;transition:color 0.15s,border-color 0.15s}
.tab-btn.active{color:#1a1a1a;border-bottom-color:#1a1a1a}
.tab-btn:hover:not(.active){color:#555}
.tab-panel{display:none}.tab-panel.active{display:block}
/* Receipt title */
.receipt-title-row{display:flex;align-items:center;gap:10px;margin-bottom:1rem;background:#fff;border:0.5px solid #e0e0d8;border-radius:12px;padding:10px 14px}
.receipt-title-label{font-size:12px;color:#888;white-space:nowrap;font-weight:500}
.receipt-title-input{flex:1;font-size:15px;font-weight:500;padding:6px 10px;border:0.5px solid #ccc;border-radius:8px;background:#fff;color:#1a1a1a;outline:none}
.receipt-title-input:focus{border-color:#999;box-shadow:0 0 0 2px rgba(0,0,0,0.07)}
.receipt-title-input::placeholder{color:#bbb;font-weight:400}
/* Save receipt modal */
.save-receipt-fields{display:flex;flex-direction:column;gap:10px;margin-bottom:14px}
.save-receipt-fields label{font-size:12px;color:#888;margin-bottom:2px;display:block}
.save-receipt-fields input{font-size:14px;padding:7px 10px;border:0.5px solid #ccc;border-radius:8px;width:100%;background:#fff;color:#1a1a1a;outline:none}
.save-receipt-fields input:focus{border-color:#999;box-shadow:0 0 0 2px rgba(0,0,0,0.07)}
/* Saved receipts list */
.saved-list{display:flex;flex-direction:column;gap:8px}
.saved-item{background:#fff;border:0.5px solid #e0e0d8;border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:box-shadow 0.15s}
.saved-item:hover{box-shadow:0 2px 8px rgba(0,0,0,0.08)}
.saved-item-info{flex:1;min-width:0}
.saved-item-title{font-size:14px;font-weight:500;color:#1a1a1a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.saved-item-meta{font-size:11px;color:#888;margin-top:2px}
.saved-item-actions{display:flex;gap:6px;flex-shrink:0}
.saved-empty{text-align:center;padding:2.5rem;color:#888;font-size:14px}
.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(60px);background:#fff;border:0.5px solid #6dbf85;border-radius:8px;padding:8px 18px;font-size:13px;transition:transform 0.25s;z-index:999;pointer-events:none;color:#1e7e34;box-shadow:0 2px 8px rgba(0,0,0,0.1)}
.toast.err{border-color:#f5b0b0;color:#c0392b}
.toast.show{transform:translateX(-50%) translateY(0)}
.mono{font-family:monospace;font-size:12px;color:#555}
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.35);z-index:200;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.modal-box{background:#fff;border:0.5px solid #ccc;border-radius:12px;padding:1.25rem;width:90%;max-width:560px;max-height:85vh;overflow-y:auto}
.modal-title{font-size:15px;font-weight:500;margin-bottom:8px;color:#1a1a1a}
.csv-area{width:100%;font-family:monospace;font-size:11px;padding:10px;border:0.5px solid #ccc;border-radius:8px;background:#fafaf7;color:#1a1a1a;height:200px;resize:none}
.modal-hint{font-size:11px;color:#888;margin-top:6px;margin-bottom:10px}
.modal-actions{display:flex;gap:8px;justify-content:flex-end}
.import-drop{border:1.5px dashed #ccc;border-radius:12px;padding:1.5rem;text-align:center;cursor:pointer;margin-bottom:12px;transition:background 0.15s}
.import-drop:hover,.import-drop.drag{background:#e8f0fe;border-color:#b0c4f5}
.import-drop-label{font-size:13px;color:#555;margin-top:6px}
.import-drop-sub{font-size:11px;color:#888;margin-top:4px}
.import-cols{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.col-select-wrap{display:flex;flex-direction:column;gap:4px}
.col-label{font-size:11px;color:#888}
.col-select{font-size:13px;padding:6px 8px;border:0.5px solid #ccc;border-radius:8px;background:#fff;color:#1a1a1a;width:100%}
.import-preview-table{width:100%;border-collapse:collapse;margin-bottom:12px;font-size:12px}
.import-preview-table th{font-size:11px;color:#888;font-weight:500;padding:5px 8px;text-align:left;border-bottom:0.5px solid #e0e0d8}
.import-preview-table td{padding:5px 8px;border-bottom:0.5px solid #e0e0d8;color:#1a1a1a}
.import-preview-table td.ok{color:#1e7e34}
.import-preview-table td.miss{color:#c0392b}
.import-preview-table tr:last-child td{border-bottom:none}
.step-indicator{font-size:11px;color:#888;margin-bottom:12px}
@media(max-width:600px){
  .summary-bar{grid-template-columns:repeat(2,1fr)}
  .import-cols{grid-template-columns:1fr}
}
/* Photo feature */
.photo-btn{width:22px;height:22px;border:0.5px solid #ccc;border-radius:4px;background:transparent;cursor:pointer;font-size:12px;line-height:1;color:#888;display:inline-flex;align-items:center;justify-content:center;padding:0;flex-shrink:0}
.photo-btn:hover{background:#f5f5f0;color:#1a1a1a}
.photo-btn.has-photo{border-color:#b0c4f5;background:#e8f0fe;color:#1a56db}
.photo-panel{padding:10px 14px;border-top:0.5px solid #e0e0d8;background:#fafaf7;display:flex;align-items:flex-start;gap:10px}
.photo-thumb{width:140px;height:140px;object-fit:cover;border-radius:6px;border:0.5px solid #e0e0d8;cursor:pointer;flex-shrink:0}
.photo-thumb-empty{width:72px;height:72px;border:1.5px dashed #ccc;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:20px;cursor:pointer;flex-shrink:0;background:#fff;color:#ccc}
.photo-thumb-empty:hover{border-color:#999;color:#999}
.photo-info{font-size:11px;color:#888;display:flex;flex-direction:column;gap:6px;justify-content:center}
.photo-remove{font-size:11px;color:#c0392b;cursor:pointer;background:none;border:none;padding:0;text-decoration:underline;cursor:pointer}
.photo-toggle-wrap{display:flex;align-items:center;gap:6px;margin-left:auto}
.photo-toggle-label{font-size:11px;color:#888}
.photo-toggle{position:relative;display:inline-block;width:32px;height:18px;flex-shrink:0}
.photo-toggle input{opacity:0;width:0;height:0}
.photo-toggle-slider{position:absolute;inset:0;background:#ccc;border-radius:18px;cursor:pointer;transition:background 0.2s}
.photo-toggle-slider:before{content:'';position:absolute;width:12px;height:12px;left:3px;top:3px;background:#fff;border-radius:50%;transition:transform 0.2s}
.photo-toggle input:checked+.photo-toggle-slider{background:#1a56db}
.photo-toggle input:checked+.photo-toggle-slider:before{transform:translateX(14px)}
/* Manage catalog */
.catalog-item{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:0.5px solid #eee}
.catalog-item:last-child{border-bottom:none}
.catalog-item-info{flex:1;min-width:0}
.catalog-item-sku{font-size:13px;font-weight:500;color:#1a1a1a}
.catalog-item-meta{font-size:11px;color:#888;margin-top:1px}
/* Photo lightbox */
.lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:999;align-items:center;justify-content:center}
.lightbox.open{display:flex}
.lightbox img{max-width:90vw;max-height:85vh;border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,0.4)}
.lightbox-close{position:fixed;top:16px;right:20px;font-size:28px;color:#fff;cursor:pointer;line-height:1;opacity:0.8}
.lightbox-close:hover{opacity:1}
</style>
</head>
<body>
<div class="wrap">
  <h1>Inventory Scanner</h1>
  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('scan')">📦 Σκανάρισμα</button>
    <button class="tab-btn" onclick="switchTab('saved')" id="saved-tab-btn">📂 Αποθηκευμένες Παραλαβές</button>
  </div>

  <!-- SCAN TAB -->
  <div class="tab-panel active" id="tab-scan">
  <div class="receipt-title-row">
    <span class="receipt-title-label">Τίτλος παραλαβής:</span>
    <input class="receipt-title-input" id="receipt-title" placeholder="π.χ. Παραλαβή Fila Μάρτιος 2026…" autocomplete="off">
  </div>
  <div class="summary-bar">
    <div class="stat"><div class="stat-label">Catalog barcodes</div><div class="stat-val" id="s-catalog">445</div></div>
    <div class="stat"><div class="stat-label">SKU σκαναρισμένα</div><div class="stat-val" id="s-codes">0</div></div>
    <div class="stat"><div class="stat-label">Νούμερα</div><div class="stat-val" id="s-sizes">0</div></div>
    <div class="stat"><div class="stat-label">Σύνολο τεμάχια</div><div class="stat-val" id="s-total">0</div></div>
  </div>
  <div class="scan-area">
    <div class="scan-row">
      <input class="scan-input" id="barcode-input" placeholder="Σκανάρισμα barcode..." autocomplete="off"/>
      <button class="btn" onclick="handleScan()">+ Καταχώριση</button>
    </div>
    <div class="hint">Σκανάρετε και πατήστε Enter — <span id="catalog-count">445</span> barcodes φορτωμένα · <strong style="color:#1e7e34">Αυτόματη αποθήκευση ενεργή</strong></div>
    <div class="preview-box" id="preview">
      <div class="preview-sku" id="prev-sku"></div>
      <div class="preview-name" id="prev-name"></div>
      <div class="preview-detail" id="prev-detail"></div>
    </div>
  </div>
  <div class="actions-row">
    <button class="btn btn-import" onclick="openImport()">↑ Εισαγωγή παραγγελίας Excel</button>
    <button class="btn" onclick="openBulkPhotoImport()" style="background:#f3e8ff;border-color:#c084fc;color:#7c3aed;font-weight:500">📷 Μαζική εισαγωγή φωτογραφιών</button>
    <button class="btn" id="manage-photos-btn" onclick="openManagePhotos()" style="background:#f3e8ff;border-color:#c084fc;color:#7c3aed;font-weight:500" title="Διαχείριση αποθηκευμένων φωτογραφιών">🗄️ Αποθήκη φωτ. <span id="photo-store-count" style="background:#7c3aed;color:#fff;border-radius:10px;padding:1px 7px;font-size:11px;margin-left:4px">…</span></button>
    <button class="btn" onclick="openManageCatalog()" style="background:#fff7ed;border-color:#fdba74;color:#c2410c;font-weight:500">📋 Ανεβασμένα Excel <span id="catalog-extra-count" style="background:#c2410c;color:#fff;border-radius:10px;padding:1px 7px;font-size:11px;margin-left:4px">0</span></button>
    <button class="btn" onclick="exportCSV()">Εξαγωγή CSV</button>
    <button class="btn" onclick="exportExcel()" style="background:#e6f4ea;border-color:#a8d5b5;color:#1e7e34;font-weight:500">📊 Εξαγωγή Excel (τελική παραλαβή)</button>
    <button class="btn" onclick="exportPDF()" style="background:#fff3e0;border-color:#ffb74d;color:#e65100;font-weight:500">📄 Εξαγωγή PDF παραλαβής</button>
    <button class="btn" onclick="openSaveReceipt()" style="background:#e6f4ea;border-color:#a8d5b5;color:#1e7e34;font-weight:500">💾 Αποθήκευση παραλαβής</button>
    <button class="btn" onclick="exportJSON()" title="Backup δεδομένων">💾 Backup</button>
    <button class="btn" onclick="importBackup()" title="Φόρτωση backup">📂 Φόρτωση backup</button>
    <button class="btn" onclick="clearAll()" style="color:#c0392b">Εκκαθάριση</button>
    <span class="save-indicator" id="save-ind">✓ Αποθηκεύτηκε</span>
    <div class="photo-toggle-wrap" title="Εμφάνιση/απόκρυψη φωτογραφιών">
      <span class="photo-toggle-label">📷 Φωτ.</span>
      <label class="photo-toggle">
        <input type="checkbox" id="photos-enabled" onchange="togglePhotosFeature(this.checked)">
        <span class="photo-toggle-slider"></span>
      </label>
    </div>
  </div>
  <div id="inventory-list"></div>
  <div id="empty-state" class="empty">Δεν υπάρχουν εγγραφές ακόμα.<br>Σκανάρετε ένα barcode ή εισάγετε παραγγελία Excel.</div>
  </div><!-- end tab-scan -->

  <!-- SAVED RECEIPTS TAB -->
  <div class="tab-panel" id="tab-saved">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
      <div style="font-size:13px;color:#555">Επιλέξτε παραλαβή για επεξεργασία ή εξαγωγή PDF</div>
      <button class="btn" onclick="deleteAllSaved()" style="color:#c0392b;font-size:12px">Διαγραφή όλων</button>
    </div>
    <div class="saved-list" id="saved-list"></div>
    <div id="saved-empty" class="saved-empty" style="display:none">Δεν υπάρχουν αποθηκευμένες παραλαβές.<br>Πηγαίνετε στο Σκανάρισμα και πατήστε "Αποθήκευση παραλαβής".</div>
  </div>
</div>

<!-- CSV Modal -->
<div class="modal-bg" id="csv-modal">
  <div class="modal-box">
    <div class="modal-title">Εξαγωγή CSV</div>
    <textarea class="csv-area" id="csv-area" readonly></textarea>
    <div class="modal-hint">Ctrl+A → Ctrl+C → επικόλληση σε Excel</div>
    <div class="modal-actions">
      <button class="btn" onclick="downloadCSV()">⬇ Κατέβασμα αρχείου</button>
      <button class="btn" onclick="copyCSV()">Αντιγραφή</button>
      <button class="btn" onclick="closeModal('csv-modal')">Κλείσιμο</button>
    </div>
  </div>
</div>

<!-- Import Modal -->
<div class="modal-bg" id="import-modal">
  <div class="modal-box" style="max-width:600px">
    <div class="modal-title">Εισαγωγή παραγγελίας από Excel / CSV</div>
    <div class="step-indicator" id="import-step">Βήμα 1 από 3 — Επιλογή αρχείου</div>
    <div id="step1">
      <div class="import-drop" id="drop-zone" onclick="document.getElementById('file-input').click()"
        ondragover="event.preventDefault();this.classList.add('drag')"
        ondragleave="this.classList.remove('drag')"
        ondrop="handleDrop(event)">
        <div style="font-size:28px">📂</div>
        <div class="import-drop-label">Κλικ ή σύρτε αρχείο εδώ</div>
        <div class="import-drop-sub">Αποδεκτά: .xlsx, .xls, .csv</div>
      </div>
      <input type="file" id="file-input" accept=".xlsx,.xls,.csv" style="display:none" onchange="handleFile(this.files[0])">
      <div class="modal-hint">Το αρχείο πρέπει να έχει στήλη με barcodes. Προαιρετικά: στήλη ποσότητας.</div>
      <div class="modal-actions"><button class="btn" onclick="closeModal('import-modal')">Ακύρωση</button></div>
    </div>
    <div id="step2" style="display:none">
      <div style="font-size:12px;color:#555;margin-bottom:10px" id="file-info"></div>
      <div class="import-cols">
        <div class="col-select-wrap"><div class="col-label">Στήλη Barcode *</div><select class="col-select" id="col-barcode" onchange="updatePreview()"></select></div>
        <div class="col-select-wrap"><div class="col-label">Στήλη Ποσότητας</div><select class="col-select" id="col-qty" onchange="updatePreview()"><option value="">— καμία (1 τεμ.) —</option></select></div>
        <div class="col-select-wrap"><div class="col-label">Στήλη SKU</div><select class="col-select" id="col-sku" onchange="updatePreview()"><option value="">— καμία —</option></select></div>
        <div class="col-select-wrap"><div class="col-label">Στήλη Νούμερου</div><select class="col-select" id="col-size" onchange="updatePreview()"><option value="">— καμία —</option></select></div>
        <div class="col-select-wrap"><div class="col-label">Στήλη Τιμής €</div><select class="col-select" id="col-price" onchange="updatePreview()"><option value="">— καμία —</option></select></div>
      </div>
      <div style="font-size:11px;color:#888;margin-bottom:8px">Προεπισκόπηση (πρώτες 5 γραμμές):</div>
      <div style="overflow-x:auto;margin-bottom:12px"><table class="import-preview-table" id="preview-table"></table></div>
      <div class="modal-actions">
        <button class="btn" onclick="goStep(1)">← Πίσω</button>
        <button class="btn btn-import" onclick="goStep(3)">Επόμενο →</button>
      </div>
    </div>
    <div id="step3" style="display:none">
