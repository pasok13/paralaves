  .chipp-spacer { display: block; height: 10pt; margin-bottom: 2px; }

  .gbody { display: flex; align-items: center; }
  .gphoto { flex-shrink: 0; padding: 6px 8px; border-right: 0.5px solid #eee; background: #fafaf7; display: flex; align-items: center; justify-content: center; }
