function deleteCatalogSku(sku) {
  if (!confirm('Διαγραφή όλων των barcodes για SKU "' + sku + '";')) return;
  // Remove all barcodes of this SKU from C (only non-base)
  Object.keys(C).forEach(k => { if (!BASE_C[k] && C[k].sku === sku) delete C[k]; });
  // Also remove from scanned data
  if (data[sku]) delete data[sku];
  saveAll(); render();
  openManageCatalog();
