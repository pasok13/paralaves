// Catalog (base + any extras) and inventory data are loaded from IndexedDB asynchronously — see initApp() at the end of this script.
let C = Object.assign({}, BASE_C);
let data = {}, collapsed = {}, parsedRows = [], importHeaders = [];

function saveAll() {
  const extra = {};
  Object.keys(C).forEach(k => { if (!BASE_C[k]) extra[k] = C[k]; });
  return Promise.all([
    idbKvSet(DATA_KEY, data),
    idbKvSet('inv_catalog_extra', extra)
  ]).then(() => {
    const ind = document.getElementById('save-ind');
    ind.classList.add('show');
    clearTimeout(window._saveT);
    window._saveT = setTimeout(() => ind.classList.remove('show'), 2000);
  }).catch(() => showToast('Σφάλμα αποθήκευσης!', true));
}

const inp = document.getElementById('barcode-input');
inp.focus();
inp.addEventListener('keydown', e => { if (e.key === 'Enter') handleScan(); });
inp.addEventListener('input', livePreview);

function livePreview() {
  const raw = inp.value.trim();
  const p = document.getElementById('preview');
  if (!raw) { p.style.display = 'none'; return; }
  const e = C[raw];
  if (e) {
    p.className = 'preview-box'; p.style.display = 'block';
    document.getElementById('prev-sku').textContent = e.sku;
    document.getElementById('prev-name').textContent = e.name || '';
    document.getElementById('prev-detail').textContent = 'Νούμερο: ' + e.size + '   |   Barcode: ' + raw;
  } else {
    p.className = 'preview-box err'; p.style.display = 'block';
    document.getElementById('prev-sku').textContent = 'Barcode δεν βρέθηκε στον κατάλογο';
    document.getElementById('prev-name').textContent = '';
    document.getElementById('prev-detail').textContent = raw;
  }
}

function handleScan() {
  const raw = inp.value.trim();
  if (!raw) return;
  const e = C[raw];
  if (!e) { showToast('Άγνωστο barcode: ' + raw, true); inp.value = ''; document.getElementById('preview').style.display = 'none'; return; }
  const { sku, size, name } = e;
  if (!data[sku]) {
    data[sku] = { name: name || '', sizes: {} };
    // Auto-attach from confirmed store
    if (_allStoredPhotos[sku]) data[sku].photo = _allStoredPhotos[sku];
    else tryAttachPendingPhoto(sku); // check pending (unmatched uploads)
  }
  data[sku].sizes[size] = (data[sku].sizes[size] || 0) + 1;
  showToast(sku + (name ? ' · ' + name : '') + ' / Νο ' + size + ' +1');
  inp.value = ''; document.getElementById('preview').style.display = 'none'; inp.focus();
  render(); saveAll();
}

function changeQty(sku, sz, d) {
  if (!data[sku]) return;
  data[sku].sizes[sz] = Math.max(0, (data[sku].sizes[sz] || 0) + d);
  if (!data[sku].sizes[sz]) { delete data[sku].sizes[sz]; if (!Object.keys(data[sku].sizes).length) delete data[sku]; }
  render(); saveAll();
}
function removeSize(sku, sz) {
  if (data[sku]) { delete data[sku].sizes[sz]; if (!Object.keys(data[sku].sizes).length) delete data[sku]; }
  render(); saveAll();
}
function toggleGroup(sku) { collapsed[sku] = !collapsed[sku]; render(); }

function render() {
  const skus = Object.keys(data).sort();
  document.getElementById('empty-state').style.display = skus.length ? 'none' : 'block';
  document.getElementById('inventory-list').innerHTML = '';
  let tp = 0, ts = 0;
  skus.forEach(sku => {
    const sizes = Object.keys(data[sku].sizes).sort((a, b) => { const n = s => parseFloat(s.replace(/[^0-9.]/g, '')) || 0; return n(a) - n(b); });
    const gt = sizes.reduce((s, sz) => s + data[sku].sizes[sz], 0);
    tp += gt; ts += sizes.length;
    const isOpen = !collapsed[sku];
    const pn = data[sku].name;
    const isNew = data[sku].isNew;
    const card = document.createElement('div');
    card.className = 'group-card';
    const noteVal = (data[sku].notes || '').replace(/"/g, '&quot;');
    const prices = data[sku].prices || {};
    const allPrices = sizes.map(sz => prices[sz]).filter(p => p != null);
    const uniquePrices = [...new Set(allPrices.map(p => p.toFixed(2)))];
    let priceBadgeHtml = '';
    if (uniquePrices.length === 1) {
      priceBadgeHtml = `<span class="group-price-badge" onclick="event.stopPropagation()" title="Τιμή από Excel">€${uniquePrices[0]}</span>`;
    } else if (uniquePrices.length > 1) {
      const minP = Math.min(...allPrices).toFixed(2);
      const maxP = Math.max(...allPrices).toFixed(2);
      priceBadgeHtml = `<span class="group-price-badge" onclick="event.stopPropagation()" title="Διαφορετικές τιμές ανά νούμερο" style="background:#fff3e0;border-color:#fdba74;color:#c2410c">€${minP}–${maxP}</span>`;
    } else if (data[sku].price != null) {
      priceBadgeHtml = `<span class="group-price-badge" onclick="event.stopPropagation()" title="Τιμή από Excel">€${Number(data[sku].price).toFixed(2)}</span>`;
    }
    const hasPhoto = !!(data[sku].photo);
    const photosOn = document.getElementById('photos-enabled').checked;
    card.innerHTML = `<div class="group-header" onclick="toggleGroup('${sku}')">
      <div class="group-left"><span class="group-title" onclick="event.stopPropagation();copySku('${sku}')" title="Κλικ για αντιγραφή κωδικού" style="cursor:pointer">${sku}${isNew ? '<span class="badge-new">ΝΕΟ</span>' : ''}</span>${pn ? `<span class="group-name">${pn}</span>` : ''}</div>
      <div class="group-meta">
        <input class="group-notes" placeholder="Σημείωση…" value="${noteVal}" onclick="event.stopPropagation()" oninput="updateNote('${sku}', this.value)" title="Περιγραφή / σημείωση">
        ${priceBadgeHtml}
        ${photosOn ? `<button class="photo-btn${hasPhoto ? ' has-photo' : ''}" onclick="event.stopPropagation();openPhotoPicker('${sku}')" title="${hasPhoto ? 'Αλλαγή φωτογραφίας' : 'Προσθήκη φωτογραφίας'}">📷</button>` : ''}
        <span class="badge">${sizes.length} νούμερα</span><span class="badge badge-total">${gt} τεμ.</span><span class="chevron ${isOpen ? 'open' : ''}">▾</span>
      </div>
    </div>
    ${isOpen ? `<div style="display:flex;align-items:stretch">
      ${photosOn && hasPhoto ? `<div style="flex-shrink:0;padding:10px 10px 10px 12px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;border-right:0.5px solid #e0e0d8;background:#fafaf7">
        <img class="photo-thumb" src="${data[sku].photo}" alt="${sku}" onclick="openLightbox('${sku}')" title="Κλικ για μεγέθυνση">
        <button class="photo-remove" onclick="removePhoto('${sku}')">✕ Αφαίρεση</button>
      </div>` : ''}
      <div style="flex:1;overflow-x:auto"><table class="size-table"><thead><tr><th style="padding-left:28px">Νούμερο</th><th style="padding-left:20px">Barcode</th><th>Τιμή €</th><th>Τεμάχια</th></tr></thead><tbody>${
      sizes.map(sz => {
        const bc = Object.keys(C).find(k => C[k].sku === sku && C[k].size === sz) || '-';
        const szPrice = prices[sz];
        const priceCell = szPrice != null ? `<span style="font-size:12px;font-weight:600;color:#1e7e34;font-family:monospace">€${szPrice.toFixed(2)}</span>` : `<span style="color:#ccc;font-size:11px">—</span>`;
        return `<tr><td style="font-weight:500;padding-left:28px">Νο ${sz}</td><td class="mono" style="padding-left:20px">${bc}</td><td>${priceCell}</td><td><div class="qty-cell">
          <button class="qty-btn" onclick="changeQty('${sku}','${sz}',-1)">−</button>
          <span class="qty-val">${data[sku].sizes[sz]}</span>
          <button class="qty-btn" onclick="changeQty('${sku}','${sz}',1)">+</button>
          <button class="qty-btn" onclick="removeSize('${sku}','${sz}')" style="margin-left:4px;font-size:11px;color:#c0392b">✕</button>
        </div></td></tr>`;
      }).join('')
    }</tbody></table></div></div>` : ''}`;
    document.getElementById('inventory-list').appendChild(card);
  });
  document.getElementById('s-codes').textContent = skus.length;
  document.getElementById('s-sizes').textContent = ts;
  document.getElementById('s-total').textContent = tp;
  document.getElementById('s-catalog').textContent = Object.keys(C).length;
  document.getElementById('catalog-count').textContent = Object.keys(C).length;
}

// ---- IMPORT ----
function openImport() { goStep(1); document.getElementById('import-modal').className = 'modal-bg open'; }
function handleDrop(e) {
  e.preventDefault(); document.getElementById('drop-zone').classList.remove('drag');
  const f = e.dataTransfer.files[0]; if (f) handleFile(f);
}
function handleFile(file) {
  if (!file) return;
  const r = new FileReader();
  if (file.name.toLowerCase().endsWith('.csv')) {
    r.onload = ev => parseCSV(ev.target.result, file.name); r.readAsText(file, 'utf-8');
  } else {
    r.onload = ev => parseXLSX(ev.target.result, file.name); r.readAsArrayBuffer(file);
  }
}
function parseXLSX(buf, fname) {
  try { const wb = XLSX.read(buf, { type: 'array' }); const ws = wb.Sheets[wb.SheetNames[0]]; finishParse(XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' }), fname); }
  catch (e) { showToast('Σφάλμα ανάγνωσης αρχείου', true); }
}
function parseCSV(text, fname) { finishParse(text.split(/\r?\n/).map(r => r.split(/[,;\t]/)), fname); }
function finishParse(rows, fname) {
  if (!rows || rows.length < 2) { showToast('Κενό αρχείο', true); return; }
  importHeaders = rows[0].map(h => String(h).trim());
  parsedRows = rows.slice(1).filter(r => r.some(c => String(c).trim() !== ''));
  document.getElementById('file-info').textContent = fname + ' — ' + parsedRows.length + ' γραμμές, ' + importHeaders.length + ' στήλες';
  populateColumnSelects(); goStep(2);
}
function populateColumnSelects() {
  ['col-barcode', 'col-qty', 'col-sku', 'col-size', 'col-price'].forEach(id => {
    const sel = document.getElementById(id);
    const isBC = id === 'col-barcode';
    sel.innerHTML = isBC ? '' : '<option value="">— καμία —</option>';
    if (id === 'col-qty') sel.innerHTML = '<option value="">— καμία (1 τεμ.) —</option>';
    importHeaders.forEach((h, i) => { sel.innerHTML += `<option value="${i}">${h || 'Στήλη ' + (i + 1)}</option>`; });
  });
  importHeaders.forEach((h, i) => {
    const hl = h.toLowerCase();
    if (/barcode|ean|upc/.test(hl)) document.getElementById('col-barcode').value = i;
    else if (/qty|ποσ|τεμ|quantity/.test(hl)) document.getElementById('col-qty').value = i;
    else if (/sku/.test(hl)) document.getElementById('col-sku').value = i;
    else if (/size|νούμ|νουμ/.test(hl)) document.getElementById('col-size').value = i;
    else if (/price|τιμ/.test(hl)) document.getElementById('col-price').value = i;
  });
  updatePreview();
}
function updatePreview() {
  const bcCol = parseInt(document.getElementById('col-barcode').value);
  const qtyCol = document.getElementById('col-qty').value;
  const skuCol = document.getElementById('col-sku').value;
  const sizeCol = document.getElementById('col-size').value;
  const priceCol = document.getElementById('col-price').value;
  let html = '<thead><tr><th>Barcode</th>';
  if (qtyCol !== '') html += '<th>Ποσότητα</th>';
  if (skuCol !== '') html += '<th>SKU</th>';
  if (sizeCol !== '') html += '<th>Νούμερο</th>';
  if (priceCol !== '') html += '<th>Τιμή €</th>';
  html += '<th>Κατάλογος</th></tr></thead><tbody>';
  parsedRows.slice(0, 5).forEach(row => {
    const bc = String(row[bcCol] || '').trim().replace(/\.0$/, '');
    const found = C[bc];
    html += `<tr><td>${bc}</td>`;
    if (qtyCol !== '') html += `<td>${String(row[parseInt(qtyCol)] || '').trim()}</td>`;
    if (skuCol !== '') html += `<td>${String(row[parseInt(skuCol)] || '').trim()}</td>`;
    if (sizeCol !== '') html += `<td>${String(row[parseInt(sizeCol)] || '').trim()}</td>`;
    if (priceCol !== '') html += `<td>${String(row[parseInt(priceCol)] || '').trim()}</td>`;
    html += `<td class="${found ? 'ok' : 'miss'}">${found ? '✓ ' + found.sku + ' / ' + found.size : 'Νέο'}</td></tr>`;
  });
  document.getElementById('preview-table').innerHTML = html + '</tbody>';
}
function goStep(n) {
  [1, 2, 3].forEach(i => document.getElementById('step' + i).style.display = i === n ? '' : 'none');
  document.getElementById('import-step').textContent = ['', 'Βήμα 1 από 3 — Επιλογή αρχείου', 'Βήμα 2 από 3 — Αντιστοίχιση στηλών', 'Βήμα 3 από 3 — Επιβεβαίωση'][n];
  if (n === 3) buildConfirm();
}
function buildConfirm() {
  const bcCol = parseInt(document.getElementById('col-barcode').value);
  const qtyCol = document.getElementById('col-qty').value;
  const skuCol = document.getElementById('col-sku').value;
  const sizeCol = document.getElementById('col-size').value;
  const priceCol = document.getElementById('col-price').value;
  let found = 0, newE = 0, skipped = 0;
  const rows = parsedRows.map(row => {
    const bc = String(row[bcCol] || '').trim().replace(/\.0$/, '');
    const qty = qtyCol !== '' ? parseInt(row[parseInt(qtyCol)]) || 1 : 1;
    const skuOv = skuCol !== '' ? String(row[parseInt(skuCol)] || '').trim() : '';
    const sizeOv = sizeCol !== '' ? String(row[parseInt(sizeCol)] || '').trim() : '';
    const priceRaw = priceCol !== '' ? parseFloat(String(row[parseInt(priceCol)] || '').replace(',', '.')) : null;
    const price = (priceRaw != null && !isNaN(priceRaw)) ? priceRaw : null;
    if (!bc) { skipped++; return null; }
    const ex = C[bc];
    if (ex) { found++; return { bc, sku: ex.sku, size: ex.size, name: ex.name || '', qty, price, isNew: false }; }
    if (skuOv && sizeOv) { newE++; return { bc, sku: skuOv, size: sizeOv, name: '', qty, price, isNew: true }; }
    skipped++; return null;
  }).filter(Boolean);
  document.getElementById('import-summary').textContent = 'Βρέθηκαν: ' + found + ' | Νέα barcodes: ' + newE + ' | Παρακαμφθέντα: ' + skipped;
  let html = '<thead><tr><th>Barcode</th><th>SKU</th><th>Νούμερο</th><th>Ποσότητα</th><th>Τιμή €</th><th>Κατάσταση</th></tr></thead><tbody>';
  rows.slice(0, 50).forEach(r => {
    const priceDisp = r.price != null ? '€' + r.price.toFixed(2) : '—';
    html += `<tr><td class="mono">${r.bc}</td><td>${r.sku}</td><td>${r.size}</td><td>${r.qty}</td><td>${priceDisp}</td><td class="${r.isNew ? 'miss' : 'ok'}">${r.isNew ? 'Νέο' : '✓'}</td></tr>`;
  });
  if (rows.length > 50) html += `<tr><td colspan="6" style="color:#888;font-size:11px">...και ${rows.length - 50} ακόμα γραμμές</td></tr>`;
  document.getElementById('confirm-table').innerHTML = html + '</tbody>';
  document.getElementById('confirm-table')._rows = rows;
}
function doImport() {
  const rows = document.getElementById('confirm-table')._rows || [];
  let added = 0, addedNew = 0;
  rows.forEach(r => {
    if (r.isNew) { C[r.bc] = { sku: r.sku, size: r.size, name: '' }; addedNew++; }
    if (!data[r.sku]) {
      data[r.sku] = { name: r.name, sizes: {}, isNew: r.isNew };
      if (_allStoredPhotos[r.sku]) data[r.sku].photo = _allStoredPhotos[r.sku];
      else tryAttachPendingPhoto(r.sku);
    }
    data[r.sku].sizes[r.size] = (data[r.sku].sizes[r.size] || 0) + r.qty;
    if (r.price != null) {
      if (!data[r.sku].prices) data[r.sku].prices = {};
      data[r.sku].prices[r.size] = r.price;
      data[r.sku].price = r.price; // legacy fallback
    }
    added++;
  });
  closeModal('import-modal'); render(); saveAll();
  updateCatalogExtraCount();
  showToast('Εισήχθησαν ' + added + ' εγγραφές' + (addedNew ? ' (+' + addedNew + ' νέα barcodes)' : ''));
}

// ---- CSV EXPORT ----
function buildCSV() {
  const skus = Object.keys(data).sort();
  if (!skus.length) return null;
  let csv = 'SKU,Προϊόν,Νούμερο,Barcode,Τεμάχια,Τιμή,Σημειώσεις\r\n';
  skus.forEach(sku => {
    Object.keys(data[sku].sizes).sort().forEach(sz => {
      const bc = Object.keys(C).find(k => C[k].sku === sku && C[k].size === sz) || '';
      const note = data[sku].notes || '';
      const prices = data[sku].prices || {};
      const price = prices[sz] != null ? Number(prices[sz]).toFixed(2) : (data[sku].price != null ? Number(data[sku].price).toFixed(2) : '');
      csv += `${sku},"${data[sku].name || ''}",${sz},${bc},${data[sku].sizes[sz]},${price},"${note}"\r\n`;
    });
  });
  return csv;
}
function exportCSV() {
  const csv = buildCSV();
  if (!csv) { showToast('Δεν υπάρχουν δεδομένα', true); return; }
  document.getElementById('csv-area').value = csv;
  document.getElementById('csv-modal').className = 'modal-bg open';
  setTimeout(() => document.getElementById('csv-area').select(), 100);
}
function downloadCSV() {
  const csv = buildCSV(); if (!csv) return;
  const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'inventory_' + new Date().toISOString().slice(0,10) + '.csv';
  a.click();
}
function copyCSV() {
  const ta = document.getElementById('csv-area'); ta.select();
  try { document.execCommand('copy'); showToast('Αντιγράφηκε!'); } catch (e) { showToast('Ctrl+C για αντιγραφή', true); }
}

// ---- EXCEL EXPORT (τελική παραλαβή) ----
function exportExcel() {
  const skus = Object.keys(data).sort();
  if (!skus.length) { showToast('Δεν υπάρχουν δεδομένα', true); return; }
  const title = document.getElementById('receipt-title').value.trim();
  const rows = [];
  let totalPcs = 0;
  skus.forEach(sku => {
    const sizes = Object.keys(data[sku].sizes).sort((a, b) => { const n = s => parseFloat(s.replace(/[^0-9.]/g, '')) || 0; return n(a) - n(b); });
    const prices = data[sku].prices || {};
    sizes.forEach(sz => {
      const bc = Object.keys(C).find(k => C[k].sku === sku && C[k].size === sz) || '';
      const price = prices[sz] != null ? Number(prices[sz]) : (data[sku].price != null ? Number(data[sku].price) : '');
      const qty = data[sku].sizes[sz];
      totalPcs += qty;
      rows.push({
        'SKU': sku,
        'Προϊόν': data[sku].name || '',
        'Νούμερο': sz,
        'Barcode': bc,
        'Τεμάχια': qty,
        'Τιμή €': price,
        'Σύνολο €': price !== '' ? +(price * qty).toFixed(2) : '',
        'Σημειώσεις': data[sku].notes || ''
      });
    });
  });
  const ws = XLSX.utils.json_to_sheet(rows);
  ws['!cols'] = [{ wch: 14 }, { wch: 24 }, { wch: 10 }, { wch: 16 }, { wch: 10 }, { wch: 10 }, { wch: 10 }, { wch: 24 }];
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Παραλαβή');
  const now = new Date();
  const dateStr = now.toISOString().slice(0, 10);
  const fname = 'Παραλαβη_' + (title ? title.replace(/[\\/:*?"<>|]/g, '_') + '_' : '') + dateStr + '.xlsx';
  XLSX.writeFile(wb, fname);
  showToast('Excel εξήχθη (' + skus.length + ' SKU · ' + totalPcs + ' τεμ.)');
}

