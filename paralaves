        </div>`
      ).join('');
      html += `<div style="font-size:11px;font-weight:600;color:#c2410c;margin-bottom:6px;text-transform:uppercase;letter-spacing:.04em">⏳ Εκκρεμείς (${pending.length})</div><div style="max-height:200px;overflow-y:auto">${pgrid}</div>`;
    }
    if (!skus.length && !pending.length) {
      html = '<div style="text-align:center;padding:1rem;color:#888">Δεν υπάρχουν αποθηκευμένες φωτογραφίες.</div>';
    }
    el.innerHTML = html;
    document.getElementById('manage-photos-modal').className = 'modal-bg open';
    updatePhotoStoreCount();
  }).catch(() => showToast('Σφάλμα ανάγνωσης αποθήκης', true));
}

function deletePendingPhoto(nameNorm) {
  idbDeletePending(nameNorm).then(() => openManagePhotos()).catch(() => {});
}

function deleteOnePhoto(sku) {
  idbDeletePhoto(sku).then(() => {
    if (data[sku]) { delete data[sku].photo; render(); }
    openManagePhotos();
    showToast('Φωτογραφία ' + sku + ' διαγράφηκε');
  }).catch(() => showToast('Σφάλμα διαγραφής', true));
}

function clearAllPhotos() {
  if (!confirm('Διαγραφή ΟΛΩΝ των αποθηκευμένων φωτογραφιών;')) return;
  openIDB().then(db => new Promise((resolve, reject) => {
    const tx = db.transaction(IDB_STORE, 'readwrite');
    tx.objectStore(IDB_STORE).clear();
    tx.oncomplete = () => resolve();
    tx.onerror = () => reject(tx.error);
  })).then(() => {
    Object.keys(data).forEach(sku => { if (data[sku]) delete data[sku].photo; });
    render();
    closeModal('manage-photos-modal');
    updatePhotoStoreCount();
    showToast('Όλες οι φωτογραφίες διαγράφηκαν');
  }).catch(() => showToast('Σφάλμα διαγραφής', true));
}

// Update count on load
setTimeout(updatePhotoStoreCount, 500);

function openLightbox(sku) {
  const photo = data[sku] && data[sku].photo;
  if (!photo) return;
  document.getElementById('lightbox-img').src = photo;
  document.getElementById('lightbox').classList.add('open');
}
function closeLightbox() {
  document.getElementById('lightbox').classList.remove('open');
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

function copySku(sku) {
  navigator.clipboard.writeText(sku).then(() => {
    showToast('✓ Αντιγράφηκε: ' + sku);
  }).catch(() => {
    // Fallback for older browsers
    const el = document.createElement('textarea');
    el.value = sku;
    el.style.position = 'fixed';
    el.style.opacity = '0';
    document.body.appendChild(el);
    el.select();
    document.execCommand('copy');
    document.body.removeChild(el);
    showToast('✓ Αντιγράφηκε: ' + sku);
  });
}
</script>
