// ---- PHOTOS (IndexedDB — μόνιμη αποθήκευση, χωρίς όριο 5MB) ----
let _currentPhotoSku = null;
const IDB_NAME = 'InventoryPhotosDB';
const IDB_STORE = 'photos';
let _idb = null;

const IDB_PENDING_STORE = 'pending_photos';
const IDB_KV_STORE = 'kv';

function openIDB() {
  return new Promise((resolve, reject) => {
    if (_idb) { resolve(_idb); return; }
    const req = indexedDB.open(IDB_NAME, 3);
    req.onupgradeneeded = e => {
      const db = e.target.result;
      if (!db.objectStoreNames.contains(IDB_STORE)) {
        db.createObjectStore(IDB_STORE, { keyPath: 'sku' });
      }
      if (!db.objectStoreNames.contains(IDB_PENDING_STORE)) {
        db.createObjectStore(IDB_PENDING_STORE, { keyPath: 'nameNorm' });
      }
      if (!db.objectStoreNames.contains(IDB_KV_STORE)) {
        db.createObjectStore(IDB_KV_STORE, { keyPath: 'key' });
      }
    };
    req.onsuccess = e => { _idb = e.target.result; resolve(_idb); };
    req.onerror = () => reject(req.error);
  });
}

// ---- Generic key/value store (replaces localStorage — inventory data, catalog extras, saved receipts, settings) ----
function idbKvGet(key) {
  return openIDB().then(db => new Promise((resolve, reject) => {
    const tx = db.transaction(IDB_KV_STORE, 'readonly');
    const req = tx.objectStore(IDB_KV_STORE).get(key);
    req.onsuccess = () => resolve(req.result ? req.result.value : undefined);
    req.onerror = () => reject(req.error);
  }));
}
function idbKvSet(key, value) {
  return openIDB().then(db => new Promise((resolve, reject) => {
    const tx = db.transaction(IDB_KV_STORE, 'readwrite');
    tx.objectStore(IDB_KV_STORE).put({ key, value });
    tx.oncomplete = () => resolve();
    tx.onerror = () => reject(tx.error);
  }));
}

// One-time migration: pull any legacy localStorage values into IndexedDB, then stop touching localStorage.
function migrateLocalStorageToIDB() {
  const legacyKeys = [DATA_KEY, 'inv_catalog_extra', 'inv_saved_receipts', 'inv_photos_enabled'];
  const jobs = legacyKeys.map(k => {
    const raw = localStorage.getItem(k);
    if (raw == null) return Promise.resolve();
    let val;
    try { val = (k === 'inv_photos_enabled') ? raw : JSON.parse(raw); } catch(e) { return Promise.resolve(); }
    return idbKvGet(k).then(existing => {
      if (existing !== undefined) return; // already migrated, don't overwrite
      return idbKvSet(k, val);
    }).then(() => localStorage.removeItem(k));
  });
  return Promise.all(jobs).catch(() => {});
}

// Save photo without SKU match — store by normalized filename for later matching
function idbSetPendingPhoto(nameNorm, originalName, dataUrl) {
  return openIDB().then(db => new Promise((resolve, reject) => {
    const tx = db.transaction(IDB_PENDING_STORE, 'readwrite');
    tx.objectStore(IDB_PENDING_STORE).put({ nameNorm, originalName, dataUrl });
    tx.oncomplete = () => resolve();
    tx.onerror = () => reject(tx.error);
  }));
}

function idbGetAllPending() {
  return openIDB().then(db => new Promise((resolve, reject) => {
    const tx = db.transaction(IDB_PENDING_STORE, 'readonly');
    const req = tx.objectStore(IDB_PENDING_STORE).getAll();
    req.onsuccess = () => resolve(req.result || []);
    req.onerror = () => reject(req.error);
  }));
}

function idbDeletePending(nameNorm) {
  return openIDB().then(db => new Promise((resolve, reject) => {
    const tx = db.transaction(IDB_PENDING_STORE, 'readwrite');
    tx.objectStore(IDB_PENDING_STORE).delete(nameNorm);
    tx.oncomplete = () => resolve();
    tx.onerror = () => reject(tx.error);
  }));
}

// Normalize helper (shared)
function normStr(s) { return s.toUpperCase().replace(/[^A-Z0-9]/g, ''); }

// Try to match a SKU string against pending photos — returns best match or null
function findPendingPhotoForSku(sku) {
  const skuNorm = normStr(sku);
  return idbGetAllPending().then(pending => {
    // 1. Exact
    let hit = pending.find(p => p.nameNorm === skuNorm);
    if (hit) return hit;
    // 2. Contains
    hit = pending.find(p => p.nameNorm.includes(skuNorm) || skuNorm.includes(p.nameNorm));
    if (hit) return hit;
    // 3. Fuzzy levenshtein ≤ 3, similarity ≥ 80%
    function lev(a, b) {
      const m = a.length, n = b.length;
      const dp = Array.from({length: m+1}, (_,i) => Array.from({length: n+1}, (_,j) => i===0?j:j===0?i:0));
      for (let i=1;i<=m;i++) for (let j=1;j<=n;j++)
        dp[i][j] = a[i-1]===b[j-1] ? dp[i-1][j-1] : 1+Math.min(dp[i-1][j],dp[i][j-1],dp[i-1][j-1]);
      return dp[m][n];
    }
    let best = null, bestDist = Infinity;
    for (const p of pending) {
      const maxLen = Math.max(skuNorm.length, p.nameNorm.length);
      const d = lev(skuNorm, p.nameNorm);
      if (d < bestDist && d <= 3 && (maxLen-d)/maxLen >= 0.80) { bestDist = d; best = p; }
    }
    return best;
  });
}

// When a new SKU appears, check pending photos and auto-attach
function tryAttachPendingPhoto(sku) {
  findPendingPhotoForSku(sku).then(hit => {
    if (!hit) return;
    if (data[sku]) data[sku].photo = hit.dataUrl;
    _allStoredPhotos[sku] = hit.dataUrl;
    idbSetPhoto(sku, hit.dataUrl)
      .then(() => idbDeletePending(hit.nameNorm))
      .then(() => { render(); showToast('📷 Φωτογραφία συνδέθηκε αυτόματα: ' + sku); })
      .catch(() => {});
  }).catch(() => {});
}

function idbGetPhoto(sku) {
  return openIDB().then(db => new Promise((resolve, reject) => {
    const tx = db.transaction(IDB_STORE, 'readonly');
    const req = tx.objectStore(IDB_STORE).get(sku);
    req.onsuccess = () => resolve(req.result ? req.result.dataUrl : null);
    req.onerror = () => reject(req.error);
  }));
}

function idbSetPhoto(sku, dataUrl) {
  return openIDB().then(db => new Promise((resolve, reject) => {
    const tx = db.transaction(IDB_STORE, 'readwrite');
    tx.objectStore(IDB_STORE).put({ sku, dataUrl });
    tx.oncomplete = () => resolve();
    tx.onerror = () => reject(tx.error);
  }));
}

function idbDeletePhoto(sku) {
  return openIDB().then(db => new Promise((resolve, reject) => {
    const tx = db.transaction(IDB_STORE, 'readwrite');
    tx.objectStore(IDB_STORE).delete(sku);
    tx.oncomplete = () => resolve();
    tx.onerror = () => reject(tx.error);
  }));
}

function idbGetAllPhotos() {
  return openIDB().then(db => new Promise((resolve, reject) => {
    const tx = db.transaction(IDB_STORE, 'readonly');
    const req = tx.objectStore(IDB_STORE).getAll();
    req.onsuccess = () => {
      const map = {};
      (req.result || []).forEach(r => { map[r.sku] = r.dataUrl; });
      resolve(map);
    };
    req.onerror = () => reject(req.error);
  }));
}

